        table.insert(lines, "")
        table.insert(lines, "═══ PATH ═══")
        table.insert(lines, getFullPath(p))
        
        table.insert(lines, "")
        table.insert(lines, "═══ HIERARCHY ═══")
        table.insert(lines, getParentHierarchy(p))
        
        -- Детали трансформации
