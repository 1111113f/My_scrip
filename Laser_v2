-- Полный путь объекта
local function getFullPath(obj)
    local path = obj.Name
    local current = obj
    while current.Parent and current.Parent ~= workspace and current.Parent ~= game do
        current = current.Parent
        path = current.Name .. " > " .. path
    end
    return path
end

-- Иерархия родителей
local function getParentHierarchy(obj, levels)
    levels = levels or 4
    local hierarchy = {}
    local current = obj.Parent
    local count = 0
    
    while current and current ~= game and count < levels do
        table.insert(hierarchy, string.format("%s (%s)", current.Name, current.ClassName))
        current = current.Parent
        count = count + 1
    end
    
    return table.concat(hierarchy, " → ")
end

-- Attachments
local function getAttachmentsInfo(part)
    local attachments = {}
    for _, child in ipairs(part:GetChildren()) do
        if child:IsA("Attachment") then
            table.insert(attachments, string.format("%s [%.1f, %.1f, %.1f]", child.Name, 
                child.Position.X, child.Position.Y, child.Position.Z))
        end
    end
    return attachments
end

-- Scripts
local function getScriptsInfo(part)
    local scripts = {}
    for _, child in ipairs(part:GetChildren()) do
        if child:IsA("Script") or child:IsA("LocalScript") or child:IsA("ModuleScript") then
            local sType = child:IsA("Script") and "Script" or (child:IsA("LocalScript") and "LocalScript" or "Module")
            local context = ""
            if child:IsA("Script") then
                context = child.RunContext == Enum.RunContext.Server and "[SERVER]" or "[CLIENT]"
            end
            table.insert(scripts, string.format("[%s]%s %s", sType:sub(1,1), context, child.Name))
        end
    end
    return scripts
end

UIS.InputBegan:Connect(function(inp,gpe)
    if gpe then return end
    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
        inputDown = true
        lockedPoint = nil
        lockedPart  = nil
    end
end)

UIS.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
        inputDown = false
    end
end)

