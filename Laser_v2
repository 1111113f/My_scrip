        table.insert(lines, string.format("Size: %.2f, %.2f, %.2f", p.Size.X, p.Size.Y, p.Size.Z))
        table.insert(lines, string.format("Rotation: %.1f°, %.1f°, %.1f°", 
            math.deg(p.Orientation.X), math.deg(p.Orientation.Y), math.deg(p.Orientation.Z)))
        table.insert(lines, string.format("Anchored: %s | CanCollide: %s | Transparency: %.2f", 
            tostring(p.Anchored), tostring(p.CanCollide), p.Transparency))
        table.insert(lines, string.format("Mass: %.2f | Reflectance: %.2f", p:GetMass(), p.Reflectance))
        
        -- Специфичное
        if p:IsA("MeshPart") then
            table.insert(lines, "")
            table.insert(lines, "═══ MESH ═══")
            table.insert(lines, string.format("MeshId: %s", p.MeshId ~= "" and p.MeshId:match("%d+") or "None"))
            table.insert(lines, string.format("TextureID: %s", p.TextureID ~= "" and p.TextureID:match("%d+") or "None"))
        elseif p:IsA("Part") and p.Shape ~= Enum.PartType.Block then
            table.insert(lines, "")
            table.insert(lines, "═══ SHAPE ═══")
            table.insert(lines, tostring(p.Shape):gsub("Enum.PartType.", ""))
        elseif p:IsA("UnionOperation") then
            table.insert(lines, "")
            table.insert(lines, "═══ UNION ═══")
            table.insert(lines, string.format("UsePartColor: %s", tostring(p.UsePartColor)))
        end
        
        -- Attachments
        local atts = getAttachmentsInfo(p)
        if #atts > 0 then
            table.insert(lines, "")
            table.insert(lines, string.format("═══ ATTACHMENTS (%d) ═══", #atts))
            for _, a in ipairs(atts) do
                table.insert(lines, "• " .. a)
            end
        end
        
        -- Scripts
        local scr = getScriptsInfo(p)
        if #scr > 0 then
            table.insert(lines, "")
            table.insert(lines, string.format("═══ SCRIPTS (%d) ═══", #scr))
            for _, s in ipairs(scr) do
                table.insert(lines, "• " .. s)
            end
        end
        
        -- Дети (кратко)
        local otherKids = {}
        for _, c in ipairs(p:GetChildren()) do
            if not c:IsA("Attachment") and not c:IsA("Script") and not c:IsA("LocalScript") and not c:IsA("ModuleScript") then
                table.insert(otherKids, string.format("%s (%s)", c.Name, c.ClassName))
            end
        end
        if #otherKids > 0 then
            table.insert(lines, "")
            table.insert(lines, string.format("═══ CHILDREN (%d/%d) ═══", math.min(#otherKids, 5), #p:GetChildren()))
            for i = 1, math.min(#otherKids, 5) do
                table.insert(lines, "• " .. otherKids[i])
            end
        end
        
